\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1041  \cf1     def _draw_text_pil(self, image, text, position, font_size=18, color=(255, 255, 255)):\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1042  \cf1         """\u20351?\u29992?PIL\u32472?\u21046?\u20013?\u25991?\u25991?\u26412?\u-248?\u26367?\u20195?cv2.putText\u-244?\u25903?\u25345?CJK\u23383?\u31526?\u-247?"""\par
