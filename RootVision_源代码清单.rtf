\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1044  \cf1         draw = ImageDraw.Draw(img_pil)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1045  \cf1         font = ImageFont.truetype("C:/Windows/Fonts/simhei.ttf", font_size)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1046  \cf1         draw.text(position, text, font=font, fill=color)\par
