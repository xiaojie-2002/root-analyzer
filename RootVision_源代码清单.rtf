\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 0336  \cf1     def _mild_contrast_enhance(self, image):\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 0337  \cf1         """\u-28805?\u24494?\u23545?\u27604?\u24230?\u22686?\u24378?\u-244?\u-28545?\u20813?\u-28729?\u24230?\u22788?\u29702?"""\par
