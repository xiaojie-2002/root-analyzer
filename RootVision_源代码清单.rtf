\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 0339  \cf1         min_val = np.min(image)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 0340  \cf1         max_val = np.max(image)\par
