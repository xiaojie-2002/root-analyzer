\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1055  \cf1     def add_scale_bar(self, image, length_mm=10, position=(50, 50), color=(255, 255, 255), thickness=2):\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1056  \cf1         """\u22312?\u22270?\u20687?\u19978?\u28155?\u21152?\u27604?\u20363?\u23610?"""\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1057  \cf1         try:\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1058  \cf1             # \u-29791?\u31639?\u27604?\u20363?\u23610?\u30340?\u20687?\u32032?\u-27265?\u24230?\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1059  \cf1             bar_length_pixels = int(length_mm / self.pixel_to_mm)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1060  \cf1 \par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1061  \cf1             # \u32472?\u21046?\u27604?\u20363?\u23610?\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1062  \cf1             x, y = position\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1063  \cf1             cv2.rectangle(image,\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1064  \cf1                           (x, y - thickness - 5),\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1065  \cf1                           (x + bar_length_pixels, y + 15),\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1066  \cf1                           (0, 0, 0), -1)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1067  \cf1 \par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1068  \cf1             cv2.line(image,\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1069  \cf1                      (x, y),\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1070  \cf1                      (x + bar_length_pixels, y),\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1071  \cf1                      color, thickness)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1072  \cf1 \par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1073  \cf1             # \u20351?\u29992?PIL\u32472?\u21046?\u25991?\u26412?\u-248?\u25903?\u25345?\u20013?\u25991?\u-247?\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1074  \cf1             label = f"\{length_mm\} mm"\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1075  \cf1             text_w, text_h = self._get_text_size_pil(label, font_size=14)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1076  \cf1             text_x = x + (bar_length_pixels - text_w) // 2\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1077  \cf1             image = self._draw_text_pil(image, label, (text_x, y + 15), font_size=14, color=color)\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1078  \cf1 \par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1079  \cf1             return image\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1080  \cf1         except Exception as e:\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1081  \cf1             print(f"\u28155?\u21152?\u27604?\u20363?\u23610?\u22833?\u-29403?: \{e\}")\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1082  \cf1             return image\par
