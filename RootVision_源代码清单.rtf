\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1049  \cf1     def _get_text_size_pil(self, text, font_size=18):\par
\pard\ql\li0\ri0\widctlpar\f1\fs18\cf3 1050  \cf1         """\u-31817?\u21462?PIL\u25991?\u26412?\u23610?\u23544?"""\par
